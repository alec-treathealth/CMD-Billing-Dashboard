# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.
# Load on macOS/zsh before running:
#   export $(cat .env | grep -v '^#' | grep -v '^$' | xargs)

# --- Supabase (project: cmd-billing-dashboard / dbpabchpvipipkzkogta) ---
SUPABASE_URL=https://dbpabchpvipipkzkogta.supabase.co
# Service-role key is used by the INGEST LOADER ONLY (bypasses RLS). Never ship
# it to the search app or the browser. Treat as a top-secret credential.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Sheets API (read-only) ---
# Auth is OAuth installed-app (org policy forbids service-account keys), so it
# does NOT live in env. Place the OAuth client (Desktop app type) at
#   secrets/oauth-client.json
# First `npm run probe` (or `npm run ingest`) runs a one-time browser consent and
# writes the refresh token to secrets/token.json; later runs are silent.
# Both files are gitignored. The loopback consent port defaults to 53682.
# OAUTH_REDIRECT_PORT=53682

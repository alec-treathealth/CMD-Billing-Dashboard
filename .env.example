# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.
# Load on macOS/zsh before running:
#   export $(cat .env | grep -v '^#' | grep -v '^$' | xargs)

# --- Supabase (project: cmd-billing-dashboard / dbpabchpvipipkzkogta) ---
SUPABASE_URL=https://dbpabchpvipipkzkogta.supabase.co
# NOTE (Phase 2 / Decision 1): the ingest no longer uses the service-role key —
# it connects as the least-privilege claims_admin role over node-postgres (below).
# Keep this only if other tooling needs the REST API; it is NOT on the app path.
# Never ship it to the search app or the browser. Treat as a top-secret credential.
SUPABASE_SERVICE_ROLE_KEY=

# --- Phase 2: least-privilege Postgres roles (node-postgres path) ---
# The query library connects as claims_reader (SELECT on claims.claims only);
# the ingest connects as claims_admin. Both roles are LOGIN with passwords set
# OUT OF BAND (ALTER ROLE ... LOGIN PASSWORD via the Supabase SQL editor / MCP) —
# the password values live ONLY in .env, never in a committed migration.
# Connect via the Supavisor pooler (the direct db.<ref>.supabase.co host is not
# resolvable without the IPv4 add-on). Username is role.<project_ref>; port 6543
# is transaction mode (no NAMED prepared statements — db.ts uses unnamed queries,
# so this is fine). TLS is enforced in db.ts (ssl), so no sslmode= is needed here.
CLAIMS_ADMIN_DATABASE_URL=postgresql://claims_admin.dbpabchpvipipkzkogta:<password>@aws-1-us-west-1.pooler.supabase.com:6543/postgres
CLAIMS_READER_DATABASE_URL=postgresql://claims_reader.dbpabchpvipipkzkogta:<password>@aws-1-us-west-1.pooler.supabase.com:6543/postgres

# --- Phase 3: results route (local dev harness only) ---
# src/server.ts is a thin Express harness over the PHI results route (NOT
# production transport — that is Phase 4 / Next.js). It authenticates GET
# /results/:query_id against a single shared Bearer token. Set a strong random
# value; it is read from env, compared in constant time, and never logged.
#   RESULTS_PORT defaults to 8787.
RESULTS_API_SECRET=
# RESULTS_PORT=8787

# --- Google Sheets API (read-only) ---
# Auth is OAuth installed-app (org policy forbids service-account keys), so it
# does NOT live in env. Place the OAuth client (Desktop app type) at
#   secrets/oauth-client.json
# First `npm run probe` (or `npm run ingest`) runs a one-time browser consent and
# writes the refresh token to secrets/token.json; later runs are silent.
# Both files are gitignored. The loopback consent port defaults to 53682.
# OAUTH_REDIRECT_PORT=53682

# --- Phase 4: search agent (Anthropic) + Next.js transport ---
# The agent's LLM client. From env ONLY — never hardcode or log it.
ANTHROPIC_API_KEY=""
# Optional model override; defaults to claude-opus-4-8 when unset.
ANTHROPIC_MODEL=""

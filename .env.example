# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.
# Load on macOS/zsh before running:
#   export $(cat .env | grep -v '^#' | grep -v '^$' | xargs)

# --- Supabase (project: cmd-billing-dashboard / dbpabchpvipipkzkogta) ---
SUPABASE_URL=https://dbpabchpvipipkzkogta.supabase.co
# Service-role key is used by the INGEST LOADER ONLY (bypasses RLS). Never ship
# it to the search app or the browser. Treat as a top-secret credential.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Sheets API (read-only) ---
# Use a service account. Grant its client_email VIEWER access to the three
# "Copy of Historical Data for ..." sheets in the "Reports for Alec AI" folder.
# Provide EITHER an absolute path to the JSON key file:
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# OR the full JSON inline (single line). If both are set, the inline JSON wins.
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.
# Load on macOS/zsh before running:
#   export $(cat .env | grep -v '^#' | grep -v '^$' | xargs)

# --- Supabase (project: cmd-billing-dashboard / dbpabchpvipipkzkogta) ---
SUPABASE_URL=https://dbpabchpvipipkzkogta.supabase.co
# NOTE (Phase 2 / Decision 1): the ingest no longer uses the service-role key —
# it connects as the least-privilege claims_admin role over node-postgres (below).
# Keep this only if other tooling needs the REST API; it is NOT on the app path.
# Never ship it to the search app or the browser. Treat as a top-secret credential.
SUPABASE_SERVICE_ROLE_KEY=

# --- Per-user app auth (Next app) ---
# The Next app's PUBLIC Supabase Auth config (NEXT_PUBLIC_SUPABASE_URL / _ANON_KEY) lives
# in app/.env.example -> copy to app/.env.local for local dev; set in the Vercel project
# env for deploys. WHO may sign in is the DB table auth_config.allowed_emails (migration
# 0018), edited in the Supabase dashboard — NOT an env var.

# --- Phase 2: least-privilege Postgres roles (node-postgres path) ---
# The query library connects as claims_reader (SELECT on claims.claims only);
# the ingest connects as claims_admin. Both roles are LOGIN with passwords set
# OUT OF BAND (ALTER ROLE ... LOGIN PASSWORD via the Supabase SQL editor / MCP) —
# the password values live ONLY in .env, never in a committed migration.
# Connect via the Supavisor pooler (the direct db.<ref>.supabase.co host is not
# resolvable without the IPv4 add-on). Username is role.<project_ref>; port 6543
# is transaction mode (no NAMED prepared statements — db.ts uses unnamed queries,
# so this is fine). TLS is enforced in db.ts (ssl), so no sslmode= is needed here.
CLAIMS_ADMIN_DATABASE_URL=postgresql://claims_admin.dbpabchpvipipkzkogta:<password>@aws-1-us-west-1.pooler.supabase.com:6543/postgres
CLAIMS_READER_DATABASE_URL=postgresql://claims_reader.dbpabchpvipipkzkogta:<password>@aws-1-us-west-1.pooler.supabase.com:6543/postgres

# --- Phase 3: results route (local dev harness only) ---
# src/server.ts is a thin Express harness over the PHI results route (NOT
# production transport — that is Phase 4 / Next.js). It authenticates GET
# /results/:query_id against a single shared Bearer token. Set a strong random
# value; it is read from env, compared in constant time, and never logged.
#   RESULTS_PORT defaults to 8787.
RESULTS_API_SECRET=
# RESULTS_PORT=8787

# --- Google Sheets API (read-only) ---
# Auth is OAuth installed-app (org policy forbids service-account keys), so it
# does NOT live in env. Place the OAuth client (Desktop app type) at
#   secrets/oauth-client.json
# First `npm run probe` (or `npm run ingest`) runs a one-time browser consent and
# writes the refresh token to secrets/token.json; later runs are silent.
# Both files are gitignored. The loopback consent port defaults to 53682.
# OAUTH_REDIRECT_PORT=53682

# --- Phase 4: search agent (Anthropic) + Next.js transport ---
# The agent's LLM client. From env ONLY — never hardcode or log it.
ANTHROPIC_API_KEY=""
# Optional model override; defaults to claude-opus-4-8 when unset.
ANTHROPIC_MODEL=""

# --- Phase 8.2: dashboard cache revalidation (exact freshness) ---
# REVALIDATE_SECRET authorizes POST /api/revalidate, which invalidates the
# dashboard aggregate cache tag immediately after ingest (instead of the 15-min
# fallback). Set this in the Next app / Vercel env. It is DISTINCT from
# RESULTS_API_SECRET (this endpoint touches no PHI). Strong random value; read
# from env, compared in constant time, never logged. If unset, the endpoint
# fails closed (401) and the 15-min fallback still keeps the dashboard fresh.
REVALIDATE_SECRET=
# REVALIDATE_URL is used by the INGEST side (src/ingest.ts) to POST after the
# matview refresh. Point it at the deployed endpoint. If either REVALIDATE_URL
# or REVALIDATE_SECRET is unset, the ingest simply skips the call (local ingest
# is never blocked). Never commit a real URL/secret.
# REVALIDATE_URL=https://<your-deployment-host>/api/revalidate

# --- CollaborateMD (CMD) Web API — 2026 payer data (SERVER-ONLY secret) ---
# The dashboard "By Payer" chart's PAST-2026-MONTH view sources payer payments
# from CMD, because claims.mv_payer_gap lacks complete Apr–May 2026 data. The
# credentials are read ONLY server-side (app/lib/server.ts) and injected into the
# env-free reader (src/collections/cmdPayer.ts); the response is aggregated to
# PAYER TOTALS before anything leaves the server. NEVER expose to the browser (no
# NEXT_PUBLIC_*), NEVER log the credentials or the response body.
#
# CMD's v1 Web API uses either an API token or HTTP Basic — set whichever your
# account uses. If NONE are set, the chart silently FALLS BACK to the matview
# date-range path (no CMD call is made), so leaving these blank is safe.
#
# Before relying on this path, run `npm run probe:cmd` with real credentials to
# confirm the request/response contract, then reconcile src/collections/cmdPayer.ts
# (the response-shape mapping there is currently an UNVERIFIED assumption).
# CMD_API_TOKEN=
# CMD_API_USERNAME=
# CMD_API_PASSWORD=
# Optional overrides (defaults target the BXR/CMD account 10027973 payer report):
# CMD_API_BASE_URL=https://webapi.collaboratemd.com
# CMD_CUSTOMER_ID=10027973
# CMD_REPORT_ID=10091828
# CMD_FILTER_ID=10147241

# --- Daily CMD rollup refresh cron (NOT YET WIRED — set these before enabling) ---
# The /api/cron/refresh-cmd-payer route refreshes the trailing window of months in
# collections.cmd_payer_facility_monthly from the live CMD report. It is dormant
# until BOTH a `crons` entry is added back to app/vercel.json AND these are set.
# Without CRON_SECRET the route fails closed (401) and never touches the DB.
#   - CRON_SECRET: shared bearer secret; Vercel Cron attaches it automatically.
#   - CMD_ROLLUP_WRITER_DATABASE_URL: least-privilege cmd_rollup_writer login
#     (migration 0013) — INSERT/DELETE only on the rollup table. NEVER claims_admin
#     or the postgres/superuser URL. Verify-full TLS, like the other DB URLs.
# CRON_SECRET=
# CMD_ROLLUP_WRITER_DATABASE_URL=

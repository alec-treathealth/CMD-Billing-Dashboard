# Next app — PUBLIC Supabase Auth config (per-user login gate).
#
# Both values are PUBLIC by design and safe in the browser (NEXT_PUBLIC_*). They are
# DISTINCT from the server-only secrets in the repo-root .env (SUPABASE_SERVICE_ROLE_KEY,
# CLAIMS_*_DATABASE_URL, RESULTS_API_SECRET, ...) which must NEVER be public. Next inlines
# NEXT_PUBLIC_* at build time.
#
# Local dev: copy to app/.env.local (gitignored) and fill in. Deploys: set in the Vercel
# project env. Until BOTH are set, app-level auth stays OFF (falls back to Vercel
# Deployment Protection). The allowlist of who may sign in is the DB table
# auth_config.allowed_emails (migration 0018) — edited in the Supabase dashboard, not here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Publishable key — modern `sb_publishable_...` or the legacy anon JWT.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

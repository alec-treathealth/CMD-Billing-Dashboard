# Next app — PUBLIC Supabase Auth config (per-user login gate).
#
# Both values are PUBLIC by design and safe in the browser (NEXT_PUBLIC_*). They are
# DISTINCT from the server-only secrets in the repo-root .env (SUPABASE_SERVICE_ROLE_KEY,
# CLAIMS_*_DATABASE_URL, RESULTS_API_SECRET, ...) which must NEVER be public. Next inlines
# NEXT_PUBLIC_* at build time.
#
# Local dev: copy to app/.env.local (gitignored) and fill in. Deploys: set in the Vercel
# project env. Until the URL + a browser key are set, app-level auth stays OFF (falls back
# to Vercel Deployment Protection). Authorization is invite-only (migration 0024): the admin
# invites users from the Supabase dashboard and a verified session IS authorization — there
# is no email allowlist.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Browser (public) key. Preferred: modern NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (sb_publishable_…).
# The legacy NEXT_PUBLIC_SUPABASE_ANON_KEY (anon JWT) is also accepted by the app.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# --- CMD Batch Reporting API (server-only; powers /dashboard/collections/explorer) ---
# SERVER-ONLY secrets — NEVER prefix NEXT_PUBLIC. The Collections Explorer runs Derek's
# CMD batch report server-side (run -> poll -> unzip -> parse). Set in app/.env.local for
# local dev and in the Vercel project env for deploys.
# CMD_API_USERNAME=
# CMD_API_PASSWORD=
# CMD_EXPLORER_REPORT_ID=10091971
# CMD_EXPLORER_FILTER_ID=10147499
# Poll budget overrides for the slow 30-day explorer report (default 3s×17 = 51s,
# fits the cron's 60s maxDuration). Tune without a redeploy if generation time shifts.
# CMD_EXPLORER_POLL_INTERVAL_MS=3000
# CMD_EXPLORER_POLL_ATTEMPTS=17

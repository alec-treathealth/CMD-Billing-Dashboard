{
  "name": "cmd-billing-claims-ingest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Phase 1: ingest historical out-of-network behavioral health claims (3 Google Sheets) into Supabase (claims_raw + typed claims). PHI — compliance layer on.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "probe": "tsx src/probe.ts",
    "probe:cmd": "tsx src/collections/cmdProbe.ts",
    "diagnose": "tsx src/diagnose.ts",
    "ingest": "tsx src/ingest.ts",
    "ingest:cmd-payer": "tsx src/collections/cmdPayerIngest.ts",
    "dbcheck": "tsx src/dbcheck.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@supabase/supabase-js": "^2.45.0",
    "googleapis": "^144.0.0",
    "pg": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
